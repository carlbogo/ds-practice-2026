      "fontSize": 18,
      "fontFamily": 1,
      "text": "Bully Algorithm Rules",
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 18,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "locked": false,
      "version": 2,
      "versionNonce": 1408738163,
      "index": "aY",
