      "updated": 1775781561629,
      "link": null,
      "containerId": null,
      "originalText": "Bully Algorithm Rules",
      "autoResize": true,
      "lineHeight": 1.3888888888888888
    },
    {
      "id": "legend-text",
      "type": "text",
      "x": 670,
      "y": 180,
      "width": 260,
      "height": 190,
      "fontSize": 13,
      "fontFamily": 1,
      "text": "1. Each executor has unique ID\n   (derived from IP last octet)\n\n2. When leader fails, any executor\n   can start election\n\n3. Executor sends Election to all\n   higher-ID processes\n\n4. If no response → declare victory\n\n5. If response → wait for\n   Coordinator message\n\n6. Winner broadcasts Coordinator\n   to all peers",
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 182,
      "strokeColor": "#495057",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "locked": false,
      "version": 2,
      "versionNonce": 1130152253,
      "index": "aZ",
      "isDeleted": false,
      "strokeStyle": "solid",
      "angle": 0,
      "seed": 1,
      "frameId": null,
      "roundness": null,
      "boundElements": [],
      "updated": 1775781561629,
      "link": null,
      "containerId": null,
      "originalText": "1. Each executor has unique ID\n   (derived from IP last octet)\n\n2. When leader fails, any executor\n   can start election\n\n3. Executor sends Election to all\n   higher-ID processes\n\n4. If no response → declare victory\n\n5. If response → wait for\n   Coordinator message\n\n6. Winner broadcasts Coordinator\n   to all peers",
      "autoResize": true,
      "lineHeight": 0.9134615384615384
    },
