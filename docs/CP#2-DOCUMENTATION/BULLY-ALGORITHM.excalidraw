    {
      "id": "phase3-desc",
      "type": "text",
      "x": 92.65426121573341,
      "y": 751.8518870449079,
      "width": 480,
      "height": 60,
      "fontSize": 14,
      "fontFamily": 1,
      "text": "1. Executor 3 (ID: 102) receives no response from higher IDs\n2. Declares itself the new leader (highest responsive ID)\n3. Sends Coordinator message to all other executors\n4. System resumes normal operation with new leader",
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 54,
      "strokeColor": "#495057",
      "backgroundColor": "transparent",
