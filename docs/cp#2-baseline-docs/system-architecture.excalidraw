    },
    {
      "id": "network-content",
      "type": "text",
      "x": 700,
      "y": 645,
      "width": 420,
      "height": 70,
      "fontSize": 14,
      "fontFamily": 1,
      "text": "1. Service Crash: Leader election triggers new leader\n2. Network Partition: Heartbeat timeout → re-election\n3. Queue Full: Orders buffer in memory (bounded)\n4. Message Loss: gRPC timeout → retry or fail-fast",
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 64,
      "strokeColor": "#495057",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "roughness": 1,
