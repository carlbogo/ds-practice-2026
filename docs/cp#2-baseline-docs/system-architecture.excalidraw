      "width": 150,
      "height": 28,
      "fontSize": 22,
      "fontFamily": 1,
      "text": "System Model",
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 20,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
