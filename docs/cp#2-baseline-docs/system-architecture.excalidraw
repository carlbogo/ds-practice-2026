    {
      "id": "network-title",
      "type": "text",
      "x": 700,
      "y": 605,
      "width": 180,
      "height": 28,
      "fontSize": 22,
      "fontFamily": 1,
      "text": "Failure Modes",
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 20,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
